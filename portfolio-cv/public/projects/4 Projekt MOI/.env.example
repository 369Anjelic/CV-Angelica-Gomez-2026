# 🤖 MOI Bot Environment Variables
# Kopiere diese Datei zu .env und trage deine Werte ein

# ============================================
# ANTHROPIC / CLAUDE API
# ============================================
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxx
# Hole deinen API Key hier: https://console.anthropic.com

# ============================================
# SERVER KONFIGURATION
# ============================================
NODE_ENV=development
# development | production
# Nutze 'development' zum Testen, 'production' für Live

PORT=3000
# Welcher Port soll der Server nutzen?

HOST=localhost
# localhost für lokal, 0.0.0.0 für Docker/Cloud

# ============================================
# BOT KONFIGURATION
# ============================================
BOT_NAME=MOI
BOT_LANGUAGE=de
# Sprache: de | en | es | fr

BOT_SYSTEM_PROMPT=Du bist MOI, ein intelligenter AI-Expert für Bot-Entwicklung. Du erklärst alles auf Deutsch, praktisch und verständlich.

MAX_TOKENS=2000
# Maximale Länge der Bot-Antworten

TEMPERATURE=0.7
# 0 = Deterministisch, 1 = Kreativ

# ============================================
# SICHERHEIT
# ============================================
CORS_ORIGIN=http://localhost:3000
# Welche Domains dürfen die API nutzen?
# Produktion: https://deine-domain.com

RATE_LIMIT_REQUESTS=100
# Requests pro Minute

RATE_LIMIT_WINDOW=60000
# Zeitfenster in Millisekunden

# ============================================
# DATENBANK (Optional)
# ============================================
DATABASE_URL=sqlite:./data/bot.db
# Für Conversation History

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=info
# error | warn | info | debug

LOG_FILE=./logs/bot.log
# Logfile Pfad

# ============================================
# DEPLOYMENT
# ============================================
VERCEL_PROJECT_ID=
# Deine Vercel Project ID (wenn du Vercel nutzt)

RAILWAY_API_TOKEN=
# Railway Token (wenn du Railway nutzt)

# ============================================
# MONITORING (Optional)
# ============================================
SENTRY_DSN=
# Für Error Tracking

ANALYTICS_TOKEN=
# Für Usage Analytics

# ============================================
# FEATURE FLAGS
# ============================================
ENABLE_STREAMING=true
# Streaming Responses?

ENABLE_CONVERSATION_HISTORY=true
# Sollen Gespräche gespeichert werden?

ENABLE_RATE_LIMITING=true
# Rate Limiting aktiv?

# ============================================
# UNWRITTEN STUDIO SPEZIFISCH
# ============================================
STUDIO_NAME=Unwritten Studio
STUDIO_EMAIL=contact@unwritten.studio
STUDIO_WEBSITE=https://unwritten.studio

# ============================================
# TIPPS:
# ============================================
# 1. Nutze https://console.anthropic.com um API Key zu holen
# 2. Kopiere diese Datei: cp .env.example .env
# 3. Editiere .env mit deinen Werten
# 4. PUSHE .env NIE zu GitHub! (steht in .gitignore)
# 5. In Production nutze Umgebungsvariablen vom Hosting
