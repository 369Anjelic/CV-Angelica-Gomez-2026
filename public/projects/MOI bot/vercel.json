{
  "version": 2,
  "name": "moi-bot",
  "buildCommand": "npm run build || echo 'no build'",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "framework": "nodejs",
  "env": {
    "NODE_ENV": "production"
  },
  "envPrefix": "ANTHROPIC_,BOT_,PORT,HOST,CORS_,RATE_LIMIT_,DATABASE_,LOG_,VERCEL_,RAILWAY_,SENTRY_,ANALYTICS_,ENABLE_,STUDIO_",
  "functions": {
    "server.js": {
      "runtime": "nodejs24.x",
      "maxDuration": 60,
      "memory": 1024,
      "routes": [
        {
          "src": "/(.*)",
          "dest": "/server.js",
          "methods": ["GET", "POST", "PUT", "DELETE", "PATCH", "HEAD", "OPTIONS"]
        }
      ]
    }
  },
  "git": {
    "deploymentEnabled": {
      "main": true
    }
  },
  "buildOutputDirectory": "out",
  "outputDirectory": "out",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/datenschutz",
      "destination": "/LEGAL.md",
      "permanent": true
    },
    {
      "source": "/privacy",
      "destination": "/LEGAL.md",
      "permanent": true
    }
  ]
}
